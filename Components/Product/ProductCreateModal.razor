@* Product Create Modal - popup jaunas preces ievadīšanai*@

@using ISO_ERP.Models
@inject ISO_ERP.Services.ProductService ProductService
@inject ISO_ERP.Services.DetailService DetailService


<div class="product-modal-overlay">

    <div class="product-modal">

    <h2 class="modal-title">
        JAUNA PRECE
    </h2>

    
    @if (!string.IsNullOrWhiteSpace(validationMessage))
        {
            <div class="alert alert-danger">
                @validationMessage
            </div>
        }

    <div class="form-row">
        <label>KATEGORIJA</label>

        <select class="form-select"
            @onchange="OnCategoryChanged">

            <option value="">
                Izvēlies kategoriju
            </option>

            @foreach (var category in Categories)
            {
                <option value="@category.Id">
                    @category.Name
                </option>
            }

        </select>
    </div>

    <div class="form-row">
        <label>NOSAUKUMS</label>

        <input class="form-input"
            placeholder="Ieraksti nosaukumu"
            autocomplete="off"
            spellcheck="false"
            @bind="productName" />
    </div>

    <div class="form-row">
        <label>KODS</label>

        <input class="form-input"
            placeholder="Ieraksti kodu"
            autocomplete="off"
            spellcheck="false"
            @bind="productCode" />
    </div>

    <div class="form-row notes-row">
        <label>PIEZĪMES</label>

        <textarea class="form-textarea"
                  placeholder="Ieraksti piezīmes"
                  @bind="productNotes"></textarea>
    </div>

    <div class="details-container">

            <div class="details-title">
                Detaļas 
            </div>

            <div class="details-list">

                @foreach (var detail in details
                    .OrderBy(x => detailDisplayOrders.GetValueOrDefault(x.Id, int.MaxValue))
                    .ThenBy(x => x.Name))
                {
                    <div class="detail-wrapper" @key="detail.Id">

                        <div class="detail-item @(selectedDetailIds.Contains(detail.Id) ? "" : "inactive")">

                            <div class="detail-order-container">
                                @if (selectedDetailIds.Contains(detail.Id))
                                {
                                    <div class="detail-order">
                                        @detailDisplayOrders.GetValueOrDefault(detail.Id, 0)
                                    </div>
                                }
                            </div>

                            <span>@detail.Name</span>

                            <input type="checkbox"
                                checked="@selectedDetailIds.Contains(detail.Id)"
                                @onchange="(e => OnDetailChanged(detail.Id, e))" />

                            @if (selectedDetailIds.Contains(detail.Id))
                            {
                                <div class="detail-move-container">
                                    <button type="button"
                                            class="detail-move-btn"
                                            @onclick="() => MoveDetailUp(detail.Id)">
                                        ↑
                                    </button>

                                    <button type="button"
                                            class="detail-move-btn"
                                            @onclick="() => MoveDetailDown(detail.Id)">
                                        ↓
                                    </button>
                                </div>

                                <button type="button"
                                        @onclick="() => ToggleSubItems(detail.Id)"
                                        class="detail-subitem-btn">
                                    +
                                </button>
                            }
                        </div>

                        @if (selectedDetailIds.Contains(detail.Id))
                        {
                            <div class="detail-subitems">

                                @if (expandedDetails.Contains(detail.Id))
                                {   
                                <input class="subitem-input"
                                    placeholder="Apakšdetaļas nosaukums"
                                    @bind="newSubItemNames[detail.Id]" />

                                <button type="button"
                                        class="subitem-add-btn"
                                        @onclick="() => SaveSubItem(detail.Id)">
                                    Pievienot
                                </button>
                                }

                                @if (subItems.ContainsKey(detail.Id))
                                {
                                    <ul class="mt-2">
                                        @foreach (var item in subItems[detail.Id])
                                        {
                                            <li class="subitem-row">

                                            <span class="subitem-name">
                                                @item.Name
                                            </span>

                                            <div class="subitem-move-container">

                                                <button type="button"
                                                        class="detail-move-btn"
                                                        @onclick="() => MoveSubItemUp(detail.Id, item)">
                                                    ↑
                                                </button>

                                                <button type="button"
                                                        class="detail-move-btn"
                                                        @onclick="() => MoveSubItemDown(detail.Id, item)">
                                                    ↓
                                                </button>

                                            </div>

                                            <button type="button"
                                                    class="subitem-delete-btn"
                                                    title="Dzēst"
                                                    @onclick="() => RemoveSubItem(detail.Id, item)">
                                                🗑
                                            </button>

                                        </li>
                                        }
                                    </ul>
                                }

                            </div>
                        }

                    </div>
                }

            </div>

        </div>

    <div class="modal-buttons">

        <button class="save-btn"
        @onclick="Save">
            SAGLABĀT
        </button>

        <button class="close-btn"
                @onclick="Close">
            AIZVĒRT
        </button>

        </div>

    </div>
</div>

@if (showSuccessMessage)
{
    <div class="success-popup">
        Prece pievienota
    </div>
}

@code {

    [Parameter]
    public EventCallback OnClose { get; set; }
    private int? selectedCategoryId;
    private string productName = string.Empty;

    private string productCode = string.Empty;

    private string? productNotes;

    private HashSet<int> expandedDetails = new();
    private Dictionary<int, string> newSubItemNames = new();
    private Dictionary<int, List<TempSubItem>> subItems = new();
    private Dictionary<int, int> detailDisplayOrders = new();
    private bool showSuccessMessage = false;
    private string validationMessage = string.Empty;
    private List<Detail> details = new();
    private List<int> selectedDetailIds = new();
    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    [Parameter]
    public List<Category> Categories { get; set; } = new();
    
    protected override async Task OnInitializedAsync()
        {
            details = await DetailService.GetAllAsync();
        }

    private async Task Save()
        {
            validationMessage = string.Empty;

            if (selectedCategoryId == null)
                {
                    validationMessage = "Izvēlieties kategoriju.";
                    return;
                }

            if (string.IsNullOrWhiteSpace(productName))
                {
                    validationMessage = "Ievadiet preces nosaukumu.";
                    return;
                }

            if (string.IsNullOrWhiteSpace(productCode))
                {
                    validationMessage = "Ievadiet preces kodu.";
                    return;
                }

            if (selectedDetailIds.Count == 0)
                {
                    validationMessage = "Pievienojiet vismaz vienu detaļu.";
                    return;
                }

            if (selectedCategoryId == null)
                return;

            var product = new Product
            {
                Name = productName,
                Code = productCode,
                Notes = productNotes,
                CategoryId = selectedCategoryId.Value,
                IsActive = true
            };

            var productDetails = selectedDetailIds
                .Select(detailId => new TempProductDetail
                {
                    DetailId = detailId,
                    DisplayOrder = detailDisplayOrders.ContainsKey(detailId)
                        ? detailDisplayOrders[detailId]
                        : 0,
                    SubItems = subItems.ContainsKey(detailId)
                        ? subItems[detailId]
                        : new List<TempSubItem>()
                })
                .ToList();

            await ProductService.AddAsync(
                    product,
                    productDetails.Select(x => new ProductDetailCreateModel
                    {
                        DetailId = x.DetailId,
                        DisplayOrder = x.DisplayOrder,
                        SubItems = x.SubItems.Select(s => new ProductDetailSubItemCreateModel
                        {
                            Name = s.Name,
                            DisplayOrder = s.DisplayOrder
                        }).ToList()
                    }).ToList());

            showSuccessMessage = true;

            StateHasChanged();

            await Task.Delay(500);

            await OnClose.InvokeAsync();
        }
    
    private void OnCategoryChanged(ChangeEventArgs e)
        {
            if (int.TryParse(e.Value?.ToString(), out var value))
            {
                selectedCategoryId = value;
            }
            else
            {
                selectedCategoryId = null;
            }
        }

    private void OnDetailChanged(int detailId, ChangeEventArgs e)
        {
            var isChecked = (bool)e.Value!;

            if (isChecked)
            {
                if (!selectedDetailIds.Contains(detailId))
                {
                    selectedDetailIds.Add(detailId);


                    if (!detailDisplayOrders.ContainsKey(detailId))
                        {
                            detailDisplayOrders[detailId] = selectedDetailIds.Count;
                        }
                    
                    NormalizeDisplayOrders();
                }
            }
            else
            {
                selectedDetailIds.Remove(detailId);

                detailDisplayOrders.Remove(detailId);

                expandedDetails.Remove(detailId);

                newSubItemNames.Remove(detailId);

                subItems.Remove(detailId);
                NormalizeDisplayOrders();
            }
        }

    private void ToggleSubItems(int detailId)
        {
            if (expandedDetails.Contains(detailId))
            {
                expandedDetails.Remove(detailId);
                return;
            }

            if (!newSubItemNames.ContainsKey(detailId))
            {
                newSubItemNames[detailId] = string.Empty;
            }

            expandedDetails.Add(detailId);
        }
    
    private async Task SaveSubItem(int detailId)
        {
            if (!newSubItemNames.TryGetValue(detailId, out var name))
                return;

            if (string.IsNullOrWhiteSpace(name))
                return;

            if (!subItems.ContainsKey(detailId))
                {
                    subItems[detailId] = new List<TempSubItem>();
                }

            subItems[detailId].Add(new TempSubItem
                {
                    Name = name.Trim(),
                    DisplayOrder = subItems[detailId].Count + 1
                });

            newSubItemNames[detailId] = string.Empty;

            expandedDetails.Remove(detailId);
        }

        private void RemoveSubItem(int detailId, TempSubItem item)
            {
                if (!subItems.ContainsKey(detailId))
                    return;

                subItems[detailId].Remove(item);
            }
        
        private class TempSubItem
            {
                public string Name { get; set; } = string.Empty;

                public int DisplayOrder { get; set; } = 0;
            }
        
        private class TempProductDetail
            {
                public int DetailId { get; set; }

                public int DisplayOrder { get; set; }

                public List<TempSubItem> SubItems { get; set; } = new();
            }

            private void NormalizeDisplayOrders()
                {
                    int order = 1;

                    foreach (var detailId in selectedDetailIds
                        .OrderBy(x => detailDisplayOrders.GetValueOrDefault(x, int.MaxValue)))
                    {
                        detailDisplayOrders[detailId] = order++;
                    }
                }

private void MoveDetailUp(int detailId)
{
    var current = detailDisplayOrders.GetValueOrDefault(detailId);

    var previous = detailDisplayOrders
        .Where(x => x.Value < current)
        .OrderByDescending(x => x.Value)
        .FirstOrDefault();

    if (previous.Key == 0)
        return;

    detailDisplayOrders[detailId] = previous.Value;
    detailDisplayOrders[previous.Key] = current;
}

private void MoveDetailDown(int detailId)
{
    var current = detailDisplayOrders.GetValueOrDefault(detailId);

    var next = detailDisplayOrders
        .Where(x => x.Value > current)
        .OrderBy(x => x.Value)
        .FirstOrDefault();

    if (next.Key == 0)
        return;

    detailDisplayOrders[detailId] = next.Value;
    detailDisplayOrders[next.Key] = current;
}

private void MoveSubItemUp(int detailId, TempSubItem item)
{
    if (!subItems.ContainsKey(detailId))
        return;

    var list = subItems[detailId];

    var index = list.FindIndex(x => ReferenceEquals(x, item));

    if (index <= 0)
        return;

    (list[index - 1], list[index]) =
        (list[index], list[index - 1]);

    for (int i = 0; i < list.Count; i++)
    {
        list[i].DisplayOrder = i + 1;
    }
}

private void MoveSubItemDown(int detailId, TempSubItem item)
{
    if (!subItems.ContainsKey(detailId))
        return;

    var list = subItems[detailId];

    var index = list.FindIndex(x => ReferenceEquals(x, item));

    if (index < 0 || index >= list.Count - 1)
        return;

    (list[index], list[index + 1]) =
        (list[index + 1], list[index]);

    for (int i = 0; i < list.Count; i++)
    {
        list[i].DisplayOrder = i + 1;
    }
}
        

}